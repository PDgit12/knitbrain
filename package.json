{
  "name": "knitbrain",
  "version": "0.11.0",
  "description": "Local-first MCP brain for coding agents: code retrieval, lossless context compression, persistent per-project memory, and a verify-gated closed loop \u2014 for Claude Code, Cursor, Copilot, and any MCP client.",
  "type": "module",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "default": "./dist/lib.js"
    }
  },
  "bin": {
    "knitbrain": "dist/index.js",
    "knitbrain-proxy": "dist/proxy/index.js",
    "knitbrain-hook": "dist/hooks/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "claude",
    "claude-code",
    "cursor",
    "copilot",
    "ai-agents",
    "coding-agent",
    "agent-memory",
    "knowledge-graph",
    "code-search",
    "retrieval",
    "token-optimization",
    "context-engineering",
    "prompt-compression",
    "context-window",
    "developer-tools",
    "local-first",
    "llm"
  ],
  "author": "Piyush Dua",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PDgit12/knitbrain.git"
  },
  "homepage": "https://github.com/PDgit12/knitbrain#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json && node -e \"['dist/index.js','dist/proxy/index.js','dist/hooks/index.js'].forEach(f=>require('fs').chmodSync(f,0o755))\"",
    "lint": "eslint .",
    "test": "vitest run",
    "bench": "tsx scripts/bench.ts",
    "e2e": "npm run build && node scripts/e2e.mjs",
    "e2e:tools": "npm run build && node scripts/e2e-tools.mjs",
    "audit:prod": "node scripts/production-audit.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run verify",
    "dev": "tsx src/index.ts",
    "proxy": "tsx src/proxy/index.ts",
    "consistency": "node scripts/consistency.mjs",
    "verify": "npm run typecheck && npm run lint && npm run build && npm run test && npm run consistency && npm run bench",
    "test:coverage": "vitest run --coverage"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vscode/tree-sitter-wasm": "^0.3.1",
    "gpt-tokenizer": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
