{
  "name": "knitbrain",
  "version": "0.1.2",
  "description": "The local-first brain for coding agents: per-project memory, task-tier workflow routing, and lossless context compression \u2014 measured ~50% of all tool-result tokens on real sessions, reproducible with one command.",
  "type": "module",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "default": "./dist/lib.js"
    }
  },
  "bin": {
    "knitbrain": "dist/index.js",
    "knitbrain-proxy": "dist/proxy/index.js",
    "knitbrain-hook": "dist/hooks/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "token-optimization",
    "context-compression",
    "llm",
    "ai-agents",
    "claude",
    "memory",
    "local-first"
  ],
  "author": "Piyush Dua",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PDgit12/knitbrain.git"
  },
  "homepage": "https://github.com/PDgit12/knitbrain#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "vitest run",
    "bench": "tsx scripts/bench.ts",
    "e2e": "npm run build && node scripts/e2e.mjs",
    "audit:prod": "node scripts/production-audit.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run verify",
    "dev": "tsx src/index.ts",
    "proxy": "tsx src/proxy/index.ts",
    "consistency": "node scripts/consistency.mjs",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build && npm run consistency && npm run bench"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vscode/tree-sitter-wasm": "^0.3.1",
    "gpt-tokenizer": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "eslint": "^10.4.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
