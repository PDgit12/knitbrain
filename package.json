{
  "name": "knitbrain",
  "version": "0.1.0",
  
  "description": "Local-first MCP server: per-project memory + workflow intelligence with always-on, lossless token/context optimization.",
  "type": "module",
  "bin": {
    "knitbrain": "dist/index.js",
    "knitbrain-proxy": "dist/proxy/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "token-optimization",
    "context-compression",
    "llm",
    "ai-agents",
    "claude",
    "memory",
    "local-first"
  ],
  "author": "Piyush Dua",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PDgit12/knitbrain.git"
  },
  "homepage": "https://github.com/PDgit12/knitbrain#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "vitest run",
    "bench": "tsx scripts/bench.ts",
    "e2e": "npm run build && node scripts/e2e.mjs",
    "audit:prod": "node scripts/production-audit.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run verify",
    "dev": "tsx src/index.ts",
    "proxy": "tsx src/proxy/index.ts",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build && npm run bench"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "gpt-tokenizer": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "eslint": "^10.4.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
