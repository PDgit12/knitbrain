{
  "name": "knitbrain",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first MCP server: per-project memory + workflow intelligence with always-on, lossless token/context optimization.",
  "type": "module",
  "bin": {
    "knitbrain": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "vitest run",
    "bench": "tsx scripts/bench.ts",
    "dev": "tsx src/index.ts",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build && npm run bench"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "gpt-tokenizer": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "eslint": "^10.4.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
